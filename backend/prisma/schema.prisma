generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String
  passwordHash String
  passwordSalt String
  createdAt    DateTime @default(now())

  sessions              Session[]
  ownedWorkspaces       Workspace[]
  workspaceMembers      WorkspaceMember[]
  authoredMergeRequests MergeRequest[]

  @@map("users")
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String   @unique
  createdAt DateTime @default(now())
  expiresAt DateTime

  @@index([userId])
  @@index([expiresAt])
  @@map("sessions")
}

model Workspace {
  id        String   @id @default(cuid())
  name      String
  ownerId   String
  owner     User     @relation(fields: [ownerId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  version   Int      @default(1)

  members         WorkspaceMember[]
  collections     WorkspaceCollection[]
  folders         WorkspaceFolder[]
  requests        WorkspaceRequest[]
  environments    WorkspaceEnvironment[]
  globalVariables WorkspaceGlobalVariable[]

  @@index([ownerId])
  @@index([id, version])
  @@map("workspaces")
}

model WorkspaceCollection {
  id               String
  workspaceId      String
  workspace        Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  name             String
  sortOrder        Int       @default(0)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  version          Int       @default(1)
  authType         String?
  bearerToken      String?
  description      String?
  preRequestScript String?
  testScript       String?
  variables        Json?
  fork             Json?

  folders  WorkspaceFolder[]
  requests WorkspaceRequest[]

  @@id([workspaceId, id])
  @@index([workspaceId, sortOrder])
  @@map("workspace_collections")
}

model WorkspaceFolder {
  id               String
  workspaceId      String
  collectionId     String
  parentFolderId   String?
  workspace        Workspace           @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  collection       WorkspaceCollection @relation(fields: [workspaceId, collectionId], references: [workspaceId, id], onDelete: Cascade)
  parentFolder     WorkspaceFolder?    @relation("WorkspaceFolderChildren", fields: [workspaceId, parentFolderId], references: [workspaceId, id], onDelete: Cascade)
  childFolders     WorkspaceFolder[]   @relation("WorkspaceFolderChildren")
  name             String
  sortOrder        Int                 @default(0)
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt
  version          Int                 @default(1)
  authType         String?
  bearerToken      String?
  description      String?
  preRequestScript String?
  testScript       String?
  variables        Json?

  requests WorkspaceRequest[]

  @@id([workspaceId, id])
  @@index([workspaceId, collectionId, parentFolderId, sortOrder])
  @@map("workspace_folders")
}

model WorkspaceRequest {
  id                     String
  workspaceId            String
  collectionId           String
  folderId               String?
  workspace              Workspace           @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  collection             WorkspaceCollection @relation(fields: [workspaceId, collectionId], references: [workspaceId, id], onDelete: Cascade)
  folder                 WorkspaceFolder?    @relation(fields: [workspaceId, folderId], references: [workspaceId, id], onDelete: Cascade)
  name                   String
  sortOrder              Int                 @default(0)
  createdAt              DateTime            @default(now())
  updatedAt              DateTime            @updatedAt
  version                Int                 @default(1)
  method                 String
  url                    String
  headers                Json?
  authType               String?
  bearerToken            String?
  bodyType               String?
  description            String?
  pathVariables          Json?
  queryParamDescriptions Json?
  queryParams            Json?
  formData               Json?
  body                   String
  preRequestScript       String?
  testScript             String?

  examples RequestExample[]

  @@id([workspaceId, id])
  @@index([workspaceId, collectionId, folderId, sortOrder])
  @@map("workspace_requests")
}

model RequestExample {
  id              String
  workspaceId     String
  requestId       String
  request         WorkspaceRequest @relation(fields: [workspaceId, requestId], references: [workspaceId, id], onDelete: Cascade)
  name            String
  sortOrder       Int              @default(0)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  version         Int              @default(1)
  originalRequest Json?
  code            Int
  status          String
  body            String
  headers         Json?

  @@id([workspaceId, id])
  @@index([workspaceId, requestId, sortOrder])
  @@map("request_examples")
}

model WorkspaceEnvironment {
  id          String
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  name        String
  sortOrder   Int       @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  version     Int       @default(1)

  variables WorkspaceEnvironmentVariable[]

  @@id([workspaceId, id])
  @@index([workspaceId, sortOrder])
  @@map("workspace_environments")
}

model WorkspaceEnvironmentVariable {
  id            String
  workspaceId   String
  environmentId String
  environment   WorkspaceEnvironment @relation(fields: [workspaceId, environmentId], references: [workspaceId, id], onDelete: Cascade)
  key           String
  value         String
  enabled       Boolean              @default(true)
  sortOrder     Int                  @default(0)
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt
  version       Int                  @default(1)

  @@id([workspaceId, id])
  @@index([workspaceId, environmentId, sortOrder])
  @@map("workspace_environment_variables")
}

model WorkspaceGlobalVariable {
  id          String
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  key         String
  value       String
  enabled     Boolean   @default(true)
  sortOrder   Int       @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  version     Int       @default(1)

  @@id([workspaceId, id])
  @@index([workspaceId, sortOrder])
  @@map("workspace_global_variables")
}

model WorkspaceMember {
  userId      String
  workspaceId String
  role        String   @default("EDITOR") // OWNER, ADMIN, EDITOR, VIEWER
  joinedAt    DateTime @default(now())

  user      User      @relation(fields: [userId], references: [id])
  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@id([userId, workspaceId])
  @@map("workspace_members")
}

model WorkspaceInvite {
  token        String    @id @default(cuid()) // The invite link token
  workspaceId  String? // Backward compatibility for older single-workspace invites
  workspaceIds String[]  @default([])
  invitedEmail String? // Null if generic share link, string if direct email invite
  createdAt    DateTime  @default(now())
  expiresAt    DateTime?

  @@map("workspace_invites")
}

model MergeRequest {
  id          String  @id @default(cuid())
  title       String
  description String?
  status      String  @default("OPEN") // OPEN, MERGED, CLOSED, REJECTED

  sourceWorkspaceId  String
  targetWorkspaceId  String
  sourceCollectionId String
  targetCollectionId String
  data               Json? // Source collection snapshot
  targetData         Json? // Target collection snapshot at MR creation time

  authorId String
  author   User   @relation(fields: [authorId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([targetWorkspaceId, createdAt])
  @@index([sourceWorkspaceId, createdAt])
  @@index([authorId])
  @@map("merge_requests")
}
