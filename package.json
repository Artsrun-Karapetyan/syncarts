{
  "name": "syncarts",
  "private": true,
  "version": "0.3.15",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -p tsconfig.app.json && vite build",
    "typecheck": "tsc -p tsconfig.app.json",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test": "bun test --isolate",
    "bump": "node scripts/bump.js",
    "check": "bun run lint && bun run test && bun run build && bun run backend:typecheck",
    "preview": "vite preview",
    "tauri": "tauri",
    "tauri:test": "cd src-tauri && cargo test",
    "backend:dev": "bun run --cwd backend dev",
    "backend:start": "bun run --cwd backend start",
    "backend:test": "bun run --cwd backend test",
    "backend:typecheck": "bun run --cwd backend typecheck",
    "backend:db:generate": "bun run --cwd backend db:generate",
    "backend:db:migrate": "bun run --cwd backend db:migrate",
    "backend:db:deploy": "bun run --cwd backend db:deploy",
    "backend:db:reset": "bun run --cwd backend db:reset",
    "db:up": "cd backend && docker compose up -d",
    "db:down": "cd backend && docker compose down",
    "db:studio": "cd backend && bunx prisma studio"
  },
  "dependencies": {
    "@tanstack/react-router": "^1.170.13",
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-deep-link": "~2",
    "@tauri-apps/plugin-dialog": "^2.7.1",
    "@tauri-apps/plugin-opener": "^2",
    "@uiw/react-json-view": "^2.0.0-alpha.43",
    "@uiw/react-textarea-code-editor": "^3.1.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.17.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-resizable-panels": "^2.0.0",
    "swr": "^2.4.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@happy-dom/global-registrator": "^20.10.6",
    "@tanstack/router-devtools": "^1.167.0",
    "@tanstack/router-plugin": "^1.168.16",
    "@tauri-apps/cli": "^2",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/bun": "^1.3.14",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@typescript-eslint/eslint-plugin": "^8.61.0",
    "@typescript-eslint/parser": "^8.61.0",
    "@vitejs/plugin-react": "^4.6.0",
    "babel-plugin-react-compiler": "^1.0.0",
    "eslint": "^10.4.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-prettier": "^5.5.6",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "eslint-plugin-react-you-might-not-need-an-effect": "^1.0.0",
    "eslint-plugin-simple-import-sort": "^13.0.0",
    "eslint-plugin-unused-imports": "^4.4.1",
    "globals": "^17.6.0",
    "happy-dom": "^20.10.6",
    "prettier": "^3.8.3",
    "typescript": "~5.8.3",
    "vite": "^7.0.4"
  }
}
